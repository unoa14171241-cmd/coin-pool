# Shared
NODE_ENV=development

# Web
NEXT_PUBLIC_APP_NAME=Coin Pool
NEXT_PUBLIC_DEFAULT_CHAIN_ID=42161
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
NEXT_PUBLIC_RPC_URL_ARBITRUM=
NEXT_PUBLIC_RPC_URL_ETHEREUM=
NEXT_PUBLIC_RPC_URL_BASE=
NEXT_PUBLIC_RPC_URL_POLYGON=

# API
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lp_manager?schema=public
ALLOWED_CHAIN_IDS=42161,1,8453,137
MAX_SLIPPAGE_BPS=100
CHALLENGE_TTL_MS=300000
CHALLENGE_STORE_BACKEND=memory
REDIS_URL=redis://localhost:6379
AUTOMATION_EXECUTION_ENABLED=false
AUTOMATION_MIN_NET_BENEFIT_USD=5
AUTOMATION_AUTO_COMPOUND_ENABLED=false
AUTOMATION_MIN_COMPOUND_FEES_USD=10
AUTOMATION_DAEMON_ENABLED=false
AUTOMATION_DAEMON_INTERVAL_MS=15000
AUTOMATION_DAEMON_MAX_WALLETS_PER_TICK=20
AUTOMATION_DAEMON_MAX_JOBS_PER_WALLET=5
AUTOMATION_DAEMON_RETRY_FAILED_LIMIT=0
AUTOMATION_DAEMON_EVALUATE_ENABLED=true
AUTOMATION_DAEMON_EVALUATE_MAX_WALLETS=100
AUTOMATION_RELAYER_ENABLED=false
AUTOMATION_RELAYER_URL=
AUTOMATION_RELAYER_API_KEY=
AUTOMATION_RELAYER_TIMEOUT_MS=10000
AUTOMATION_RELAYER_WAIT_CONFIRMATION=false
AUTOMATION_TX_CONFIRM_TIMEOUT_MS=120000
ARBITRUM_RPC_URL=
MAINNET_RPC_URL=
BASE_RPC_URL=
POLYGON_RPC_URL=

# Profit distribution (required for daily distribution)
PLATFORM_WALLET=0x000000000000000000000000000000000000dEaD
# Admin wallets allowed to trigger POST /profit/daily-distribution/trigger (comma-separated). PLATFORM_WALLET is always allowed.
ADMIN_WALLETS=

# Daily USDC distribution scheduler
DAILY_DISTRIBUTION_SCHEDULER_ENABLED=false
DAILY_DISTRIBUTION_SCHEDULER_HOUR_UTC=0
DAILY_DISTRIBUTION_SCHEDULER_MINUTE_UTC=0
DAILY_DISTRIBUTION_CHECK_INTERVAL_MS=3600000

# Minimum position value (USD) for validation
MIN_POSITION_VALUE_USD=500

# Ethereum Mainnet: auto execution disabled by default (manual only)
MAINNET_AUTO_EXECUTION_DISABLED=true
